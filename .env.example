# ---------------------------------------------------------------------------
# Web3Forms access keys (https://web3forms.com) — free, no account required.
# Copy this file to `.env.local` and paste your keys below.
#
# The contact form must deliver every submission to BOTH inboxes:
#   - madebypietu@gmail.com
#   - webco.owners@gmail.com
#
# On Web3Forms' FREE tier, one access key delivers to exactly ONE inbox. So:
#   1. Go to https://web3forms.com, enter madebypietu@gmail.com, get a key.
#      -> paste it as NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY
#   2. Repeat with webco.owners@gmail.com to get a second key.
#      -> paste it as NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY_2
#
# The site fires one submission per key, so both inboxes receive every message.
# (If you upgrade to Web3Forms PRO, a single key + the built-in `ccemail`
#  fallback already covers the second inbox — the second key is then optional.)
#
# The build succeeds WITHOUT these set; the form will simply show a friendly
# "email us directly" message until keys are added.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-for-madebypietu
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY_2=your-web3forms-access-key-for-webco-owners

# ---------------------------------------------------------------------------
# Admin dashboard (/admin) + first-party analytics
#
# 1. ADMIN_PASSWORD — the single password used to log in at /admin/login.
#    Pick something long and random. Sessions are signed with a key derived
#    from it (set ADMIN_SESSION_SECRET too if you ever want to rotate
#    sessions without changing the password).
#
# 2. DATABASE_URL — Neon Postgres connection string. Easiest path:
#    Vercel dashboard → Storage → Create Database → Neon (Postgres) →
#    connect it to this project. Vercel injects DATABASE_URL automatically
#    in production; locally run `vercel env pull .env.local`.
#
# 3. After the database is connected, run once:  npm run db:setup
#
# Without these set, the public site still builds and works fine — analytics
# events are simply dropped and /admin shows setup instructions.
# ---------------------------------------------------------------------------

ADMIN_PASSWORD=choose-a-long-random-password
# ADMIN_SESSION_SECRET=optional-extra-secret
# DATABASE_URL=postgres://user:pass@host/db  (injected by the Neon integration on Vercel)
